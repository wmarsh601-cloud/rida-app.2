# ================================================
# RIDA Platform - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# For Vercel, add these as Environment Variables
# ================================================

# ================================================
# APPLICATION
# ================================================
NEXT_PUBLIC_APP_NAME="RIDA"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ================================================
# DATABASE
# ================================================
# Option 1: SQLite (Development only - NOT for production)
# DATABASE_URL="file:./dev.db"

# Option 2: Vercel Postgres (Recommended for Vercel)
# DATABASE_URL="postgres://default:xxxxx@xxxxx.postgres.vercel-storage.com/verceldb?sslmode=require"

# Option 3: Neon Postgres
# DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Option 4: Supabase
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Option 5: PlanetScale (MySQL)
# DATABASE_URL="mysql://username:password@aws.connect.psdb.cloud/dbname?sslaccept=strict"

# ================================================
# GOOGLE MAPS API
# ================================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# Google Maps API endpoints (optional - for custom implementations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# ================================================
# AUTHENTICATION
# ================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# ================================================
# SESSION CONFIGURATION
# ================================================
SESSION_DURATION_HOURS="168"  # 7 days
SESSION_CLEANUP_INTERVAL_HOURS="6"

# ================================================
# WALLET & PAYMENTS
# ================================================
# Stripe (for card payments)
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# ================================================
# NOTIFICATIONS
# ================================================
# Firebase (Push notifications)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# SendGrid (Email)
SENDGRID_API_KEY="SG.xxxxx"
SENDGRID_FROM_EMAIL="noreply@your-domain.com"

# Twilio (SMS)
TWILIO_ACCOUNT_SID="ACxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ================================================
# FILE STORAGE
# ================================================
# Vercel Blob (for file uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxx"

# AWS S3 (Alternative)
AWS_ACCESS_KEY_ID="AKIAxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxx"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"

# ================================================
# REDIS (Optional - for caching and rate limiting)
# ================================================
# Upstash Redis
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxx"

# ================================================
# MONITORING & ANALYTICS
# ================================================
# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@o123456.ingest.sentry.io/1234567"

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXX"

# ================================================
# FEATURE FLAGS
# ================================================
ENABLE_MARKETPLACE="true"
ENABLE_DRIVER_APP="true"
ENABLE_ADMIN_DASHBOARD="true"
ENABLE_PROMO_CODES="true"
ENABLE_REFERRALS="true"

# ================================================
# RIDE CONFIGURATION
# ================================================
DEFAULT_COUNTRY="CR"
DEFAULT_CURRENCY="CRC"
DEFAULT_LANGUAGE="es"

# Surge pricing
SURGE_ENABLED="true"
SURGE_MAX_MULTIPLIER="3.0"

# Driver matching
DRIVER_SEARCH_RADIUS_KM="5"
DRIVER_REQUEST_TIMEOUT_SECONDS="30"
MAX_RETRY_ATTEMPTS="3"

# ================================================
# RATE LIMITING
# ================================================
RATE_LIMIT_REQUESTS_PER_MINUTE="60"
RATE_LIMIT_RIDE_REQUESTS_PER_HOUR="10"

# ================================================
# SECURITY
# ================================================
# CORS origins (comma-separated)
CORS_ORIGINS="https://your-app.vercel.app,https://your-custom-domain.com"

# IP whitelist for admin (comma-separated)
ADMIN_IP_WHITELIST=""

# ================================================
# DEVELOPMENT (Do not use in production)
# ================================================
NODE_ENV="production"
DEBUG="false"
LOG_LEVEL="info"  # debug, info, warn, error
